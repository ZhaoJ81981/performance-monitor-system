# 性能监控系统环境变量配置
# 复制此文件为 .env 并填写真实值
# 注意：.env 文件不要提交到git

# InfluxDB配置
INFLUXDB_USER=influx_admin
INFLUXDB_PASSWORD=YOUR_STRONG_PASSWORD_HERE  # 至少16字符，包含大小写字母、数字、特殊字符
INFLUXDB_ADMIN_TOKEN=YOUR_RANDOM_TOKEN_HERE  # 使用 openssl rand -base64 32 生成

# Grafana配置
GRAFANA_USER=grafana_admin
GRAFANA_PASSWORD=YOUR_STRONG_PASSWORD_HERE  # 至少16字符

# API配置
API_KEYS=YOUR_API_KEY_1,YOUR_API_KEY_2  # 多个API密钥用逗号分隔

# 生成强密码示例命令：
# openssl rand -base64 24
# 或使用密码管理器生成

# 安全建议：
# 1. 每个环境使用不同的密码
# 2. 定期轮换密码（建议每90天）
# 3. 使用密码管理器存储
# 4. 不要共享密码文件